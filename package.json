{
  "name": "eslint-plugin-node-core-test",
  "version": "0.2.0",
  "description": "ESLint rules for node:test",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin"
  ],
  "homepage": "https://github.com/chris48s/eslint-plugin-node-core-test",
  "author": "chris48s",
  "type": "module",
  "main": "./lib/index.js",
  "exports": "./lib/index.js",
  "files": [
    "lib"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chris48s/eslint-plugin-node-core-test.git"
  },
  "scripts": {
    "lint": "npm-run-all \"lint:*\"",
    "lint:eslint-docs": "npm-run-all \"update:eslint-docs -- --check\"",
    "lint:js": "eslint .",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check .",
    "test": "node --experimental-test-coverage --test-coverage-include='lib/**/*.js' --test-coverage-exclude='tests/**/*.js' --test tests/**/*.js",
    "update:eslint-docs": "eslint-doc-generator"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-doc-generator": "^3.2.0",
    "eslint-plugin-eslint-plugin": "^7.1.1",
    "eslint-plugin-jsdoc": "^62.7.1",
    "eslint-plugin-n": "^17.0.0",
    "eslint-plugin-prettier": "^5.5.5",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "prettier-plugin-jsdoc": "^1.8.0"
  },
  "engines": {
    "node": "^22.13.0 || >=24"
  },
  "peerDependencies": {
    "eslint": ">=9.15.0"
  },
  "license": "MIT"
}
